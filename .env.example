# poom-tools — template (commit ตัวนี้ได้ · ห้ามใส่ค่าจริง)
# copy เป็น .env.local แล้วเติมค่าจาก Supabase ของภูมเอง (Settings → API)

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# server เท่านั้น — ห้ามให้หลุดไป client / ห้าม commit ค่าจริง
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
